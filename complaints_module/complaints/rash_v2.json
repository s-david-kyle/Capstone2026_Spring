{
  "version": "1.0.0",
  "complaint_id": "rash",
  "display_name": "Rash",
  "ui_name": "Rash",
  "ui_label": "Rash",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "skin",
  "related_systems": {
    "high_yield": ["constitutional_infectious", "allergic_drug", "mucosal"],
    "selective_cross_system": ["joint_vasculitic", "respiratory_anaphylaxis", "hematologic"],
    "contextual": ["travel_contact_exposure", "immunocompromise"]
  },
  "pivot_triggers": {
    "fever": "purpuric_sepsis_pattern",
    "shortness_of_breath": "anaphylaxis_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "distribution", "appearance"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 3,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Rash requires thorough anaphylaxis, infection, and drug reaction screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "distribution", "appearance"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "skin"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "distribution", "appearance"],
      "early_danger_screen": ["mucosal_involvement", "facial_or_tongue_swelling", "shortness_of_breath", "fever"],
      "extended_characterize": ["spread", "itch_or_pain", "blanching", "severity", "triggers"],
      "critical_followup": ["purpura_nonblanching", "skin_sloughing_or_blistering", "severe_pain_out_of_proportion", "confusion_or_hypotension"],
      "high_priority_followup": ["associated_symptoms", "new_medication", "recent_infection", "joint_pain", "eye_symptoms", "genital_symptoms", "travel_history", "sick_contact_exposure", "new_pet_or_plant_exposure", "chemical_exposure", "tick_or_insect_bite", "weight_loss", "lymph_node_swelling"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "distribution", "appearance"],
      "early_danger_screen": ["mucosal_involvement", "recent_change_in_pattern"],
      "extended_characterize": ["spread", "itch_or_pain", "blanching", "severity", "triggers"],
      "critical_followup": ["purpura_nonblanching", "skin_sloughing_or_blistering", "severe_pain_out_of_proportion", "confusion_or_hypotension"],
      "high_priority_followup": ["associated_symptoms", "new_medication", "recent_infection", "joint_pain", "eye_symptoms", "genital_symptoms", "travel_history", "sick_contact_exposure", "new_pet_or_plant_exposure", "chemical_exposure", "tick_or_insect_bite", "weight_loss", "lymph_node_swelling", "facial_or_tongue_swelling", "shortness_of_breath", "fever"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
