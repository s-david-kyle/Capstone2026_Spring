{
  "version": "1.0.0",
  "complaint_id": "vaginal_discharge",
  "display_name": "Vaginal Discharge",
  "ui_name": "Vaginal Discharge",
  "ui_label": "Vaginal Discharge",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "gynecologic",
  "related_systems": {
    "high_yield": ["genitourinary", "sexual_reproductive", "infectious_systemic"],
    "selective_cross_system": ["pregnancy_related", "dermatologic_mucosal", "pelvic_abdominal"],
    "contextual": ["sexual_history", "menstrual_history", "medication_antibiotic_history"]
  },
  "pivot_triggers": {
    "abdominal_pain": "pid_pattern",
    "dysuria_hematuria": "genitourinary_overlap_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "discharge_amount", "discharge_color"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 3,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Vaginal discharge requires thorough STI, PID, and malignancy screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "discharge_amount", "discharge_color"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "gynecologic"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "discharge_amount", "discharge_color", "discharge_consistency", "discharge_odor"],
      "early_danger_screen": ["lower_abdominal_or_pelvic_pain", "fever", "heavy_or_unusual_bleeding"],
      "extended_characterize": ["itching_or_irritation", "timing_with_cycle", "functional_impact"],
      "critical_followup": ["postcoital_or_postmenopausal_bleeding", "severe_vulval_pain_or_swelling", "retained_foreign_body_concern", "sexual_assault_or_safeguarding_concern", "pregnancy_context"],
      "high_priority_followup": ["associated_symptoms", "dysuria", "frequency_or_urgency", "dyspareunia", "genital_ulcers_or_sores", "rash_or_skin_change", "recent_antibiotics", "diabetes_history", "known_sti_exposure"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "discharge_amount", "discharge_color", "discharge_consistency", "discharge_odor"],
      "early_danger_screen": ["lower_abdominal_or_pelvic_pain", "recent_change_in_pattern"],
      "extended_characterize": ["itching_or_irritation", "timing_with_cycle", "functional_impact"],
      "critical_followup": ["postcoital_or_postmenopausal_bleeding", "severe_vulval_pain_or_swelling", "retained_foreign_body_concern", "sexual_assault_or_safeguarding_concern", "pregnancy_context"],
      "high_priority_followup": ["associated_symptoms", "dysuria", "frequency_or_urgency", "dyspareunia", "genital_ulcers_or_sores", "rash_or_skin_change", "recent_antibiotics", "diabetes_history", "known_sti_exposure", "fever", "heavy_or_unusual_bleeding"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
