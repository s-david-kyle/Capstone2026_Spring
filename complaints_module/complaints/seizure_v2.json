{
  "version": "1.0.0",
  "complaint_id": "seizure",
  "display_name": "Seizure",
  "ui_name": "Seizure",
  "ui_label": "Seizure",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "neurological",
  "related_systems": {
    "high_yield": [
      "metabolic_toxic",
      "cardiovascular",
      "infectious"
    ],
    "selective_cross_system": [
      "structural",
      "pregnancy"
    ],
    "contextual": [
      "witness_history",
      "substance_medication"
    ]
  },
  "pivot_triggers": {
    "loss_of_consciousness": "cns_infection_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": [
      "presenting_complaint_narrative",
      "event_timing",
      "duration",
      "witnessed",
      "prodrome"
    ],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 4,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Seizure requires thorough neurological, metabolic, and infectious screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 5,
      "secondary_question_budget_override_if_red_flag": 8,
      "priority_question_ids_if_secondary": [
        "event_timing",
        "duration",
        "witnessed",
        "prodrome"
      ],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "neurological"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": [
      "opening",
      "core_characterize",
      "early_danger_screen",
      "extended_characterize",
      "critical_followup",
      "high_priority_followup",
      "context_and_history"
    ],
    "default_profile": {
      "opening": [
        "presenting_complaint_narrative"
      ],
      "core_characterize": [
        "event_timing",
        "duration",
        "witnessed",
        "prodrome",
        "seizure_type",
        "aura_status"
      ],
      "early_danger_screen": [
        "ongoing_confusion",
        "focal_deficit_post_ictal",
        "fever_or_meningism",
        "head_injury"
      ],
      "extended_characterize": [
        "aura_features",
        "post_ictal_state",
        "injury_sustained",
        "prior_seizure_history"
      ],
      "critical_followup": [
        "status_epilepticus_concern",
        "substance_or_overdose",
        "tongue_biting",
        "incontinence",
        "hypoglycaemia_concern",
        "pregnancy_context"
      ],
      "high_priority_followup": [
        "associated_symptoms",
        "triggered_or_provoked",
        "sleep_deprivation_trigger",
        "alcohol_withdrawal",
        "new_medication_or_toxin",
        "known_epilepsy",
        "family_history_epilepsy",
        "prior_brain_pathology"
      ],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
