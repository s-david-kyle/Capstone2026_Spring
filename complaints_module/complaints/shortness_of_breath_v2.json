{
  "version": "1.0.0",
  "complaint_id": "shortness_of_breath",
  "display_name": "Shortness of Breath",
  "ui_name": "Shortness of Breath",
  "ui_label": "Shortness of Breath",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "respiratory",
  "related_systems": {
    "high_yield": ["cardiovascular", "constitutional", "airway"],
    "selective_cross_system": ["hematologic_metabolic", "anxiety"],
    "contextual": ["exposure_trigger", "thromboembolic_risk"]
  },
  "pivot_triggers": {
    "chest_pain": "acute_cardiac_pattern",
    "cough": "pneumonia_or_sepsis_pattern",
    "oedema": "acute_heart_failure_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "severity", "exertional_tolerance"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 4,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Shortness of breath requires thorough cardiac, respiratory, and thromboembolic screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "severity", "exertional_tolerance"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "respiratory"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity", "exertional_tolerance"],
      "early_danger_screen": ["rest_dyspnea", "unable_to_speak_full_sentences", "chest_pain", "cyanosis_or_confusion", "orthopnea_or_pnd", "wheeze"],
      "extended_characterize": ["timing_pattern", "course", "triggers", "relieving_factors"],
      "critical_followup": ["hemoptysis", "stridor_or_airway_swelling", "syncope_or_near_syncope"],
      "high_priority_followup": ["associated_symptoms", "cough", "sputum", "fever", "leg_swelling", "palpitations", "pleuritic_pain", "prior_clot_history", "known_asthma_or_copd", "anxiety_or_panic_context", "recent_immobility_or_travel"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity", "exertional_tolerance"],
      "early_danger_screen": ["rest_dyspnea", "chest_pain", "orthopnea_or_pnd", "recent_change_in_pattern"],
      "extended_characterize": ["timing_pattern", "course", "triggers", "relieving_factors"],
      "critical_followup": ["hemoptysis", "stridor_or_airway_swelling", "syncope_or_near_syncope"],
      "high_priority_followup": ["associated_symptoms", "cough", "sputum", "fever", "leg_swelling", "palpitations", "pleuritic_pain", "prior_clot_history", "known_asthma_or_copd", "anxiety_or_panic_context", "recent_immobility_or_travel", "unable_to_speak_full_sentences", "cyanosis_or_confusion", "wheeze"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
