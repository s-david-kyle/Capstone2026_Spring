{
  "version": "1.0.0",
  "complaint_id": "headache",
  "display_name": "Headache",
  "ui_name": "Headache",
  "ui_label": "Headache",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "neurological",
  "related_systems": {
    "high_yield": [
      "ophthalmologic",
      "constitutional_infectious",
      "musculoskeletal_meningeal"
    ],
    "selective_cross_system": [
      "cardiovascular_vascular",
      "pregnancy_postpartum"
    ]
  },
  "routing_metadata": {
    "accepts_handoff_from": [
      "pain"
    ],
    "handoff_behavior": "If routed from pain, do not re-ask generic pain-site questions; continue with headache-specific onset, duration, severity, and early danger screening."
  },
  "start_sequence_contract": {
    "approved_start_sequence": [
      "presenting_complaint_narrative",
      "onset",
      "duration",
      "severity"
    ],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then switch to the selected question schedule profile."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 5,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Headache requires thorough red-flag screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 5,
      "secondary_question_budget_override_if_red_flag": 8,
      "priority_question_ids_if_secondary": [
        "onset",
        "duration",
        "severity",
        "sudden_onset",
        "weakness"
      ],
      "selection_rule": "If headache is secondary, ask only the listed priority questions unless a red-flag branch activates."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "neurological"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If thunderclap, meningitic, acute neurologic, ocular emergency, or pregnancy-related danger patterns activate, borrow first from extended_characterize and high_priority_followup before using context history reserve.",
      "If the narrative strongly suggests a typical recurrent primary headache without red flags, cap extended characterization and preserve ROS/context budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": [
      "opening",
      "core_characterize",
      "early_danger_screen",
      "extended_characterize",
      "critical_followup",
