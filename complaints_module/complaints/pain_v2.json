      "canonical_concept": "dominant_pain_site_if_multiple"
    },
    "severity_extreme": {
      "field": "severity_extreme",
      "phase": "early_danger_screen",
      "text": "Before we go further, is this pain a 9 or 10 out of 10, the worst pain you have ever felt?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED",
        "SEVERITY_BELOW_8"
