  "derived_red_flag_patterns": {
    "universal_pain_red_flag_pattern": {
      "fields": [
        "severity_extreme",
        "sudden_maximal_onset"
      ],
      "min_matches": 1,
      "description": "Either extreme severity or sudden maximal onset in any pain presentation."
    },
    "haemodynamic_compromise_pain_pattern": {
      "fields": [
        "pain_with_collapse_or_syncope"
      ],
      "min_matches": 1,
      "description": "Pain associated with collapse, syncope, or near-syncope."
    },
    "high_risk_host_pain_pattern": {
      "fields": [
        "immunocompromised_status"
      ],
      "min_matches": 1,
      "description": "Pain in an immunocompromised or active-cancer host."
    }
