{
  "version": "1.0.0",
  "complaint_id": "cough",
  "display_name": "Cough",
  "ui_name": "Cough",
  "ui_label": "Cough",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "respiratory",
  "related_systems": {
    "high_yield": ["constitutional", "airway", "cardiovascular"],
    "selective_cross_system": ["ent_upper_airway", "gastroesophageal"],
    "contextual": ["smoking_exposure", "travel_tb_risk"]
  },
  "pivot_triggers": {
    "fever": "pneumonia_or_sepsis_pattern",
    "shortness_of_breath": "respiratory_distress_pattern",
    "weight_loss": "malignancy_or_tb_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "frequency", "dry_or_productive"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 4,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Cough requires thorough respiratory, cardiac, and infectious screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "frequency", "dry_or_productive"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "respiratory"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity"],
      "early_danger_screen": ["hemoptysis", "shortness_of_breath", "chest_pain", "fever"],
      "extended_characterize": ["frequency", "timing_pattern", "triggers", "dry_or_productive", "sputum_character"],
      "critical_followup": ["confusion_or_hypoxia", "stridor", "immunocompromised_status"],
      "high_priority_followup": ["associated_symptoms", "weight_loss", "wheeze", "night_cough", "post_tussive_vomiting", "tb_exposure", "travel_history", "heartburn", "aspiration_or_choking_after_lying_or_eating", "allergic_triggers", "recent_viral_illness", "pe_leg_swelling", "prior_clot_history", "recent_immobility_or_travel"],
      "context_and_history": ["occupational_exposure", "smoke_exposure", "household_illness"]
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity"],
      "early_danger_screen": ["hemoptysis", "shortness_of_breath", "chest_pain", "recent_change_in_pattern"],
      "extended_characterize": ["frequency", "timing_pattern", "triggers", "dry_or_productive", "sputum_character"],
      "critical_followup": ["confusion_or_hypoxia", "stridor", "immunocompromised_status"],
      "high_priority_followup": ["associated_symptoms", "weight_loss", "wheeze", "night_cough", "post_tussive_vomiting", "tb_exposure", "travel_history", "heartburn", "aspiration_or_choking_after_lying_or_eating", "allergic_triggers", "recent_viral_illness", "pe_leg_swelling", "prior_clot_history", "recent_immobility_or_travel", "fever"],
      "context_and_history": ["occupational_exposure", "smoke_exposure", "household_illness"]
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
