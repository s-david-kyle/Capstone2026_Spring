    "profile_switch_rules": [
      {
        "rule_id": "vasovagal_likely",
        "trigger": {
          "op": "all",
          "conditions": [
            {
              "op": "field_text_contains_any",
              "field_ref": "prodrome",
              "value": [
                "nausea",
                "warmth",
                "lightheaded",
                "dimming",
                "pale",
                "sweat"
              ]
            },
            {
              "op": "field_text_contains",
              "field_ref": "recovery_pattern",
              "value": "minute"
            },
            {
              "op": "field_equals",
              "field_ref": "chest_pain",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "palpitations",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "seizure_features",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "focal_neurologic_symptoms",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "head_injury",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "family_history_sudden_death",
              "value": false
            },
            {
              "op": "field_equals",
              "field_ref": "during_exertion",
              "value": false
            }
          ]
        },
        "action": "use vasovagal_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
