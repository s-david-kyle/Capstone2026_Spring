    "ros_mode": {
      "target_ros_questions": 2,
      "max_ros_questions": 3,
      "pathological_system_first": true,
      "pathological_system": "genitourinary"
    },
    "context_mode": {
      "target_context_questions": 2,
      "max_context_questions": 3
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "character", "frequency_or_urgency", "severity"],
      "early_danger_screen": ["fever_or_rigors", "loin_pain", "retention_or_anuria", "immunocompromised_status", "painless_haematuria"],
      "extended_characterize": ["haematuria_type", "flank_or_loin_pain", "functional_impact", "sex_related_symptom_timing", "vaginal_or_penile_discharge"],
