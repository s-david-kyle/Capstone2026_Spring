  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 3,
      "ros_reserve": 2,
      "context_history_reserve": 2,
      "rationale": "Complaint owns its own budget because clinical complexity and acceptable drift tolerance differ by presentation."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 6,
      "priority_question_ids_if_secondary": ["onset", "duration", "character", "frequency_or_urgency"],
