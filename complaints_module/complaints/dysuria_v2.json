      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "character", "frequency_or_urgency", "severity"],
      "early_danger_screen": ["fever_or_rigors", "loin_pain", "recent_change_in_pattern"],
      "extended_characterize": ["haematuria_type", "flank_or_loin_pain", "functional_impact", "sex_related_symptom_timing", "vaginal_or_penile_discharge"],
      "critical_followup": ["visible_blood_clots", "bilateral_symptoms"],
      "high_priority_followup": ["associated_symptoms", "recent_catheter", "prior_uti", "prior_stones", "anticoagulant_use", "weight_loss", "family_history_bladder_or_kidney_cancer", "retention_or_anuria", "immunocompromised_status", "painless_haematuria"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
