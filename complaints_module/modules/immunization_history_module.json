{
  "module_name": "immunization_history_module",
  "version": "1.0.0",
  "description": "Reusable conditional immunization history module for pediatric, infectious, respiratory, TB-risk, or other selected encounters. Run only when the activation rules fire.",
  "ui_render_rule": "Use ui_label for all visible labels. Do not show raw backend field ids in the UI.",
  "summary_rendering": "Render as an Immunization history subsection when used, or append to PMH / PSH if the target summary template has no dedicated immunization section.",
  "questions": [
    {
      "field": "immunization_record_available",
      "ui_label": "Immunization record available",
      "phase": "context_and_history",
      "text": "Do you have an immunization record available, or do you know which vaccines have already been received?",
      "response_type": "SHORT_TEXT",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ]
    },
    {
      "field": "childhood_immunizations_current",
      "ui_label": "Childhood immunizations current",
      "phase": "context_and_history",
      "text": "Are the routine childhood immunizations up to date, as far as you know?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "PATIENT_PEDIATRIC_OR_CAREGIVER_HISTORY_RELEVANT",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "childhood_immunizations_current_details"
    },
    {
      "field": "influenza_immunization_recent",
      "ui_label": "Recent influenza vaccine",
      "phase": "context_and_history",
      "text": "Was the influenza vaccine received during the most recent season, if eligible?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SUSPECTED_INFECTIOUS_PRESENTATION_OR_RESPIRATORY",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "influenza_immunization_recent_details"
    },
    {
      "field": "covid_immunization_recent",
      "ui_label": "Recent COVID vaccine",
      "phase": "context_and_history",
      "text": "Has a recent COVID vaccine or booster been received, if eligible?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SUSPECTED_INFECTIOUS_PRESENTATION_OR_RESPIRATORY",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "covid_immunization_recent_details"
    },
    {
      "field": "pneumococcal_immunization_history",
      "ui_label": "Pneumococcal vaccine history",
      "phase": "context_and_history",
      "text": "Has a pneumococcal vaccine been received before, if eligible?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "ELDERLY_OR_HIGH_RISK_RESPIRATORY_PRESENTATION",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "pneumococcal_immunization_history_details"
    },
    {
      "field": "bcg_immunization_history",
      "ui_label": "BCG vaccine history",
      "phase": "context_and_history",
      "text": "Has a BCG vaccine ever been received, if known?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "POSSIBLE_TB_PRESENTATION",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "bcg_immunization_history_details"
    },
    {
      "field": "meningococcal_or_hib_immunization_history",
      "ui_label": "Meningococcal or Hib vaccine history",
      "phase": "context_and_history",
      "text": "Have meningococcal or Hib vaccines been received before, if known?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "POSSIBLE_CNS_INFECTION_PRESENTATION",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ],
      "capture_detail_if_positive": true,
      "detail_field": "meningococcal_or_hib_immunization_history_details"
    },
    {
      "field": "other_relevant_immunization_history",
      "ui_label": "Other relevant immunization history",
      "phase": "context_and_history",
      "text": "Is there any other relevant immunization or vaccine history you think we should know about?",
      "response_type": "SHORT_TEXT",
      "skip_if": [
        "FIELD_ALREADY_CAPTURED"
      ]
    }
  ],
  "field_order": [
    "immunization_record_available",
    "childhood_immunizations_current",
    "influenza_immunization_recent",
    "covid_immunization_recent",
    "pneumococcal_immunization_history",
    "bcg_immunization_history",
    "meningococcal_or_hib_immunization_history",
    "other_relevant_immunization_history"
  ],
  "session_rule": "Run once per session only when activation rules fire. Use it before PMH/PSH and other closing history modules, and skip any question already captured in the narrative or complaint body.",
  "activation_rules": [
    "PATIENT_PEDIATRIC_OR_CAREGIVER_HISTORY_RELEVANT",
    "SUSPECTED_INFECTIOUS_PRESENTATION",
    "ELDERLY_OR_HIGH_RISK_RESPIRATORY_PRESENTATION",
    "POSSIBLE_TB_PRESENTATION",
    "POSSIBLE_CNS_INFECTION_PRESENTATION"
  ],
  "hard_session_cap_questions": 40,
  "session_non_repeat_required": true,
  "load_after": [
    "symptom_clerking",
    "ros_if_used"
  ],
  "sequence_ref": "shared.module_order",
  "module_sequence_contract": {
    "load_once_per_session": true,
    "load_after": [
      "symptom_clerking",
      "ros_if_used"
    ],
    "respect_session_non_repeat": true,
    "respect_hard_session_cap_questions": 30,
    "hard_session_cap_questions": 40
  }
}