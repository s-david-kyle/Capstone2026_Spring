{
  "module_name": "gynecologic_history_module",
  "version": "1.0.0",
  "description": "Reusable gynecologic, menstrual, and pregnancy-context module used only when the encounter makes pregnancy, menstrual, or gynecologic history clinically relevant.",
  "ui_render_rule": "Use ui_label or text in the UI. Never show raw backend field ids.",
  "questions": [
    {
      "field": "pregnancy_context",
      "ui_label": "Pregnancy context",
      "phase": "context_and_history",
      "text": "Could you be pregnant now, or are you recently postpartum?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEX_FEMALE_REPRODUCTIVE_AGE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "pregnancy_context_details",
      "if_positive_ask": ["pregnancy_context_details"],
      "sensitive_topic": true
    },
    {
      "field": "pregnancy_context_details",
      "ui_label": "Pregnancy details",
      "phase": "context_and_history",
      "text": "How far along are you? Or how many weeks postpartum?",
      "response_type": "SHORT_TEXT",
      "ask_if": "SEX_FEMALE_REPRODUCTIVE_AGE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "last_menstrual_period",
      "ui_label": "Last menstrual period",
      "phase": "context_and_history",
      "text": "If relevant and you know it, when was the first day of your last menstrual period?",
      "response_type": "TEMPORAL_OR_SHORT_TEXT",
      "ask_if": "SEX_FEMALE_REPRODUCTIVE_AGE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "timing_with_cycle",
      "ui_label": "Timing with cycle",
      "phase": "context_and_history",
      "text": "Do these symptoms seem related to your menstrual cycle?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEX_FEMALE_REPRODUCTIVE_AGE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "timing_with_cycle_details",
      "sensitive_topic": true
    },
    {
      "field": "contraceptive_use",
      "ui_label": "Contraceptive use",
      "phase": "context_and_history",
      "text": "Are you using any contraception or hormonal treatment that may be relevant to this problem?",
      "response_type": "SHORT_TEXT",
      "ask_if": "SEX_FEMALE_REPRODUCTIVE_AGE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "menopausal_status",
      "ui_label": "Menopausal status",
      "phase": "context_and_history",
      "text": "Are you still having periods regularly, are they irregular, or have they stopped completely?",
      "response_type": "SHORT_TEXT",
      "ask_if": "SEX_FEMALE",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "douching",
      "ui_label": "Douching or internal products",
      "phase": "context_and_history",
      "text": "Have you used douching, vaginal washes, or internal products recently if that might be relevant here?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "GYNECOLOGIC_CONTEXT_RELEVANT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "douching_details",
      "sensitive_topic": true
    },
    {
      "field": "local_hygiene_products",
      "ui_label": "Local hygiene products",
      "phase": "context_and_history",
      "text": "Have you recently changed any pads, soaps, creams, lubricants, or other local products that may be relevant?",
      "response_type": "SHORT_TEXT",
      "ask_if": "GYNECOLOGIC_CONTEXT_RELEVANT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "gynecologic_history_other",
      "ui_label": "Other gynecologic history",
      "phase": "context_and_history",
      "text": "Is there any other gynecologic or obstetric history we should know about that has not already been discussed?",
      "response_type": "SHORT_TEXT",
      "ask_if": "GYNECOLOGIC_CONTEXT_RELEVANT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    }
  ],
  "field_order": [
    "pregnancy_context",
    "pregnancy_context_details",
    "last_menstrual_period",
    "timing_with_cycle",
    "contraceptive_use",
    "menopausal_status",
    "douching",
    "local_hygiene_products",
    "gynecologic_history_other"
  ],
  "session_rule": "Run once per session only when the encounter has a gynecologic, lower-abdominal, vomiting, urogenital, or pregnancy-sensitive context. Skip any question already answered in the complaint body or elsewhere in session state.",
  "hard_session_cap_questions": 40,
  "session_non_repeat_required": true,
  "load_after": [
    "immunization_history_module_if_activated"
  ],
  "sequence_ref": "shared.module_order",
  "module_sequence_contract": {
    "load_once_per_session": true,
    "load_after": [
      "immunization_history_module_if_activated"
    ],
    "respect_session_non_repeat": true,
    "respect_hard_session_cap_questions": 30,
    "hard_session_cap_questions": 40
  },
  "activation_rules": [
    "GYNECOLOGIC_CONTEXT_RELEVANT"
  ],
  "note": "The pregnancy_context question is asked by this module for all complaints except those that ask it earlier in their own schedule (e.g., vomiting). The engine will skip this module's pregnancy_context if already captured."
}