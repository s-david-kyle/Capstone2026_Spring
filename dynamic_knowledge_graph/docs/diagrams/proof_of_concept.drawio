        <mxCell id="G4cJtlao1i6TVZgc5M13-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;b&gt;retrieve_pubmed_articles&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters:&lt;/b&gt; symptoms (list)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns:&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;- article_collection (list)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;- pmids (list)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Returns a list of 10 PubMed articles relevant to list of symptoms&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="175" x="20" y="20" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;llm_question_formation&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;symptoms (str)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;: response (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Uses basic prompt engineering to create a question given a list of symptoms. Will return None if there is an error querying the API.&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="175" x="20" y="140" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;llm_article_summary&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;article (str)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;: response (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Instructs the LLM to summarize an article into a single paragraph. Will return None if there is an error querying the API&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="175" x="20" y="267" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;extract_text&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;: text (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;: text_extract (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Helper function that uses regex to find text between symptoms and diagnosis in MTS dialogue. Returns None if no match is made.&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="175" x="220" y="20" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;remove_floats&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;: text (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;: text (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Helper function that uses regex to convert numerical results from extract_text() into empty strings&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="175" x="420" y="20" as="geometry" />
        </mxCell>
