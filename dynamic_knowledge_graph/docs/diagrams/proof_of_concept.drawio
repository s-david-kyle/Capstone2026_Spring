          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-22" parent="G4cJtlao1i6TVZgc5M13-13" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;llm_process_mts_dialogue&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- dialogues (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- patient_question (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;: response (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Uses prompt engineering to generate a new question based off of the most recent patient_question and dialogues from MTS dialogue&lt;/font&gt;&lt;/div&gt;" vertex="1">
