        <mxCell id="G4cJtlao1i6TVZgc5M13-21" parent="G4cJtlao1i6TVZgc5M13-13" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;doctor_dialogue_mimic&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- symptoms (list)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- patient_question (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- question (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- mts_dialogue_used (bool)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- processed_dialogue (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Creates &quot;extracted_text&quot; column in mts_dialogue DataFrame, which only contains symptom information for each dialogue. This column is queried using symptoms list for matches. Matching dialogue is combined into a single string including row numbers from mts_dialogue. llm_process_mts_dialogue() is called to form a question using extracted dialogue, which is returned along with a flag if dialogue was used and what that dialogue was.&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="313" width="175" x="440" y="498.5" as="geometry" />
        </mxCell>
