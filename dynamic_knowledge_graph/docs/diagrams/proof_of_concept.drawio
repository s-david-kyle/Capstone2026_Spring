        <mxCell id="G4cJtlao1i6TVZgc5M13-17" parent="G4cJtlao1i6TVZgc5M13-13" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;query_llm_symptom_check&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;: prompt (str)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;symptoms (list)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Queries the LLM API to extract&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;a list of symptoms based off of a patient statement. Can also return None if none are found.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="170" x="10" y="595" as="geometry" />
        </mxCell>
        <mxCell id="G4cJtlao1i6TVZgc5M13-24" edge="1" parent="G4cJtlao1i6TVZgc5M13-13" source="G4cJtlao1i6TVZgc5M13-19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="G4cJtlao1i6TVZgc5M13-21" value="">
