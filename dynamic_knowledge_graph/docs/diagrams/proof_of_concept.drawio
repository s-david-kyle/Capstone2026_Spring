        <mxCell id="G4cJtlao1i6TVZgc5M13-19" parent="G4cJtlao1i6TVZgc5M13-13" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;umls_retrieval&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Parameters&lt;/b&gt;:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- symptoms (list)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- user_id (int)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- dialogue_turn (int)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Returns&lt;/b&gt;:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;- umls_symptoms (DataFrame)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Logic: &lt;/b&gt;Iterates through symptoms list and queries UMLS terms. Returns back a DataFrame containing standardized symptom name and it&#39;s semantic type (sign or symptom, finding, food, etc)&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="175" x="212.5" y="560" as="geometry" />
        </mxCell>
