{
  "module_name": "drug_history_module",
  "version": "1.0.0",
  "description": "Reusable medication, allergy, and recent-treatment history module applied once per session after complaint clerking and ROS.",
  "ui_render_rule": "Use ui_label or text in the UI. Never show raw backend field ids.",
  "session_cap_questions": 5,
  "session_non_repeat_required": true,
  "load_once_per_session": true,
  "questions": [
    {
      "field": "MedicationsTreatments",
      "ui_label": "Current medications and treatments",
      "phase": "context_and_history",
      "text": "What medicines, supplements, injections, inhalers, or other treatments are you using now or have used recently that may be relevant to this problem?",
      "response_type": "SHORT_TEXT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "compound_question": true,
      "extract_entities_if_positive": true
    },
    {
      "field": "Allergies",
      "ui_label": "Allergies",
      "phase": "context_and_history",
      "text": "Do you have any medication, food, or other allergies or bad reactions we should know about?",
      "response_type": "SHORT_TEXT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"]
    },
    {
      "field": "recent_antibiotics_history",
      "ui_label": "Recent antibiotics",
      "phase": "context_and_history",
      "text": "Have you taken any antibiotics recently?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "INFECTIOUS_OR_GU_PRESENTATION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "recent_antibiotics_history_details"
    }
  ],
  "field_order": [
    "MedicationsTreatments",
    "Allergies",
    "recent_antibiotics_history"
  ]
}