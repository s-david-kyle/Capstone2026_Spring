{
  "module_name": "social_family_history_module",
  "version": "1.0.0",
  "description": "Reusable social, family, smoking, alcohol, recreational-drug, and sexual-exposure history module applied once per session. It should not repeat anything already captured in complaint clerking, the narrative, ROS, or other modules.",
  "ui_render_rule": "Use ui_label or text in the UI. Never show raw backend field ids.",
  "session_cap_questions": 8,
  "session_non_repeat_required": true,
  "load_once_per_session": true,
  "questions": [
    {
      "field": "smoking_history",
      "ui_label": "Smoking history",
      "phase": "context_and_history",
      "text": "Do you smoke, vape, or use tobacco now, or have you done so in the past in a way that may be relevant to this problem?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "smoking_history_details",
      "sensitive_topic": true
    },
    {
      "field": "alcohol_history",
      "ui_label": "Alcohol use",
      "phase": "context_and_history",
      "text": "Do you drink alcohol in a way that may be relevant to this problem, including any recent heavy use if that matters here?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "alcohol_history_details",
      "sensitive_topic": true
    },
    {
      "field": "recreational_drug_use",
      "ui_label": "Recreational drug use",
      "phase": "context_and_history",
      "text": "Do you use any recreational or non-prescribed drugs that may be relevant to this problem?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "recreational_drug_use_details",
      "sensitive_topic": true
    },
    {
      "field": "sexual_history",
      "ui_label": "Sexual history",
      "phase": "context_and_history",
      "text": "I ask this routinely because it can affect what may be causing the symptoms and what tests are needed. Are you sexually active, and is there any sexual history you want us to know about?",
      "response_type": "SHORT_TEXT",
      "ask_if": "SEXUAL_HISTORY_RELEVANT_SESSION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    },
    {
      "field": "new_partner",
      "ui_label": "New sexual partner",
      "phase": "context_and_history",
      "text": "Have you had any new sexual partner recently?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEXUAL_HISTORY_RELEVANT_SESSION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "new_partner_details",
      "sensitive_topic": true
    },
    {
      "field": "partner_symptoms",
      "ui_label": "Partner symptoms",
      "phase": "context_and_history",
      "text": "Has a partner had symptoms such as discharge, sores, or burning?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEXUAL_HISTORY_RELEVANT_SESSION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "partner_symptoms_details",
      "sensitive_topic": true
    },
    {
      "field": "known_sti_exposure",
      "ui_label": "Known STI exposure",
      "phase": "context_and_history",
      "text": "Do you know of any recent STI exposure?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEXUAL_HISTORY_RELEVANT_SESSION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "known_sti_exposure_details",
      "sensitive_topic": true
    },
    {
      "field": "recent_unprotected_sex",
      "ui_label": "Recent sex without barrier protection",
      "phase": "context_and_history",
      "text": "Has there been recent sex without barrier protection?",
      "response_type": "BOOLEAN_WITH_OPTIONAL_DETAILS",
      "ask_if": "SEXUAL_HISTORY_RELEVANT_SESSION",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "capture_detail_if_positive": true,
      "detail_field": "recent_unprotected_sex_details",
      "sensitive_topic": true
    },
    {
      "field": "FamilyHistory",
      "ui_label": "Family history",
      "phase": "context_and_history",
      "text": "Is there any family history that may be relevant to this problem and that has not already been discussed?",
      "response_type": "SHORT_TEXT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"]
    },
    {
      "field": "SocialHistory",
      "ui_label": "Social and exposure history",
      "phase": "context_and_history",
      "text": "Is there anything in your home, work, travel, living situation, or exposures that may be relevant to this problem and that we have not already discussed?",
      "response_type": "SHORT_TEXT",
      "skip_if": ["FIELD_ALREADY_CAPTURED"],
      "sensitive_topic": true
    }
  ],
  "field_order": [
    "smoking_history",
    "alcohol_history",
    "recreational_drug_use",
    "sexual_history",
    "new_partner",
    "partner_symptoms",
    "known_sti_exposure",
    "recent_unprotected_sex",
    "FamilyHistory",
    "SocialHistory"
  ]
}