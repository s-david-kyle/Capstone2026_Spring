{
  "version": "1.0.0",
  "complaint_id": "dizziness",
  "display_name": "Dizziness",
  "ui_name": "Dizziness",
  "ui_label": "Dizziness",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "neurological_vestibular",
  "related_systems": {
    "high_yield": ["cardiovascular", "neurological_central"],
    "selective_cross_system": ["metabolic", "medications"],
    "contextual": ["positional", "infectious"]
  },
  "pivot_triggers": {
    "syncope": "cardiac_syncope_pattern",
    "headache": "acute_neurologic_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "character", "severity"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 3,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Dizziness requires thorough cardiac, neurological, and vestibular screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "character", "severity"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "neurological_vestibular"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "character", "severity"],
      "early_danger_screen": ["sudden_onset", "neurologic_symptoms", "hearing_loss", "tinnitus", "recent_change_in_pattern"],
      "extended_characterize": ["triggers", "course", "functional_impact"],
      "critical_followup": ["headache_or_neck_pain", "diplopia_or_dysarthria", "nausea_vomiting", "fall_risk", "new_medication"],
      "high_priority_followup": ["associated_symptoms", "positional_component", "valsalva_trigger", "prior_episodes", "ear_infection_or_pressure", "anxiety_context", "cardiovascular_risk"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "character", "severity"],
      "early_danger_screen": ["sudden_onset", "neurologic_symptoms", "recent_change_in_pattern"],
      "extended_characterize": ["triggers", "course", "functional_impact"],
      "critical_followup": ["headache_or_neck_pain", "diplopia_or_dysarthria", "nausea_vomiting", "fall_risk", "new_medication"],
      "high_priority_followup": ["associated_symptoms", "positional_component", "valsalva_trigger", "prior_episodes", "ear_infection_or_pressure", "anxiety_context", "cardiovascular_risk", "hearing_loss", "tinnitus"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
