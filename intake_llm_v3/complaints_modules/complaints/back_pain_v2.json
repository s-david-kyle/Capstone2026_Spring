{
  "version": "1.0.0",
  "complaint_id": "back_pain",
  "display_name": "Back Pain",
  "ui_name": "Back Pain",
  "ui_label": "Back Pain",
  "can_be_primary": true,
  "can_be_secondary": true,
  "parent_symptom": "pain",
  "routing_metadata": {
    "accepts_handoff_from": ["pain"],
    "handoff_behavior": "If routed from the parent symptom, skip generic router questions and continue with complaint-specific core characterization."
  },
  "primary_system": "musculoskeletal_spine",
  "related_systems": {
    "high_yield": ["neurological", "genitourinary", "constitutional"],
    "selective_cross_system": ["vascular", "trauma"],
    "contextual": ["cancer_infection_risk", "pregnancy"]
  },
  "pivot_triggers": {
    "weakness": "cauda_equina_pattern",
    "dysuria_hematuria": "renal_colic_pattern",
    "chest_pain": "aortic_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "timing", "duration", "severity", "location"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 4,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Back pain requires thorough cauda equina, infection, malignancy, fracture, and aortic screening. Increased budget to ensure critical followup and high priority questions are asked before modules."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": ["onset", "duration", "severity", "location"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "musculoskeletal_spine"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "timing", "duration", "severity", "location", "character"],
      "early_danger_screen": ["leg_weakness", "saddle_numbness", "urinary_retention_or_incontinence", "fecal_incontinence", "night_pain"],
      "extended_characterize": ["radiation", "course", "aggravating_factors", "relieving_factors", "functional_impact"],
      "critical_followup": ["fever", "weight_loss", "trauma_history", "history_of_cancer", "iv_drug_use_or_immunosuppression", "abdominal_pulsation_or_tearing_pain", "syncope"],
      "high_priority_followup": ["associated_symptoms", "sciatica", "numbness_or_tingling", "rest_pain", "flank_pain_or_hematuria", "prior_back_problems", "osteoporosis_or_steroid_use", "work_or_lifting_trigger"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "timing", "duration", "severity", "location", "character"],
      "early_danger_screen": ["night_pain", "recent_change_in_pattern"],
      "extended_characterize": ["radiation", "course", "aggravating_factors", "relieving_factors", "functional_impact"],
      "critical_followup": ["fever", "weight_loss", "trauma_history", "history_of_cancer", "iv_drug_use_or_immunosuppression", "abdominal_pulsation_or_tearing_pain", "syncope"],
      "high_priority_followup": ["leg_weakness", "saddle_numbness", "urinary_retention_or_incontinence", "fecal_incontinence", "sciatica", "numbness_or_tingling", "rest_pain", "flank_pain_or_hematuria", "prior_back_problems", "osteoporosis_or_steroid_use", "work_or_lifting_trigger"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
