{
  "version": "1.0.0",
  "complaint_id": "sore_throat",
  "display_name": "Sore Throat",
  "ui_name": "Sore Throat",
  "ui_label": "Sore throat",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "ent_upper_airway",
  "related_systems": {
    "high_yield": ["constitutional_infectious", "lymphatic"],
    "selective_cross_system": ["airway", "hematologic_malignancy"],
    "contextual": ["immunocompromise"]
  },
  "pivot_triggers": {
    "fever": "possible_sepsis_pattern",
    "swelling_or_lump": "malignancy_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": ["presenting_complaint_narrative", "onset", "duration", "severity", "location"],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 3,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Sore throat requires airway, infectious, and malignancy screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 3,
      "secondary_question_budget_override_if_red_flag": 6,
      "priority_question_ids_if_secondary": ["onset", "duration", "severity"],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "ent_upper_airway"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": ["opening", "core_characterize", "early_danger_screen", "extended_characterize", "critical_followup", "high_priority_followup", "context_and_history"],
    "default_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity", "location"],
      "early_danger_screen": ["airway_compromise", "drooling_or_inability_to_swallow", "trismus", "muffled_voice", "stridor"],
      "extended_characterize": ["swallowing_difficulty", "voice_change", "functional_impact"],
      "critical_followup": ["neck_stiffness", "fever", "immunocompromised_status"],
      "high_priority_followup": ["associated_symptoms", "lymph_node_swelling", "rash", "tonsillar_exudate", "ear_pain", "recent_sick_contact", "weight_loss", "night_sweats", "sexual_exposure"],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": ["presenting_complaint_narrative"],
      "core_characterize": ["onset", "duration", "severity", "location"],
      "early_danger_screen": ["airway_compromise", "drooling_or_inability_to_swallow", "recent_change_in_pattern"],
      "extended_characterize": ["swallowing_difficulty", "voice_change", "functional_impact"],
      "critical_followup": ["neck_stiffness", "fever", "immunocompromised_status"],
      "high_priority_followup": ["associated_symptoms", "lymph_node_swelling", "rash", "tonsillar_exudate", "ear_pain", "recent_sick_contact", "weight_loss", "night_sweats", "sexual_exposure", "trismus", "muffled_voice", "stridor"],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            { "op": "duration_gte", "field_ref": "duration", "value": 4, "unit": "weeks" },
            { "op": "field_below", "field_ref": "severity", "value": 6 }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
