      "extended_characterize": ["course", "radiation", "aggravating_factors", "relieving_factors", "functional_impact"],
      "critical_followup": ["hematemesis_or_melena", "blood_in_stool", "abdominal_distension", "unable_to_pass_stool_or_flatus", "syncope_or_collapse", "pulsatile_mass_or_tearing_to_back", "pregnancy_context"],
      "high_priority_followup": ["associated_symptoms", "atrial_fibrillation_or_vascular_history", "migratory_pain_to_rlq", "loss_of_appetite", "change_in_bowel_habit", "diarrhea", "constipation", "dysuria", "urinary_frequency_or_urgency", "hematuria", "vaginal_bleeding", "vaginal_discharge", "unusual_food_exposure", "prior_episodes", "prior_abdominal_surgery", "weight_loss", "jaundice", "trauma_history", "fever_or_rigors", "persistent_vomiting"],
      "context_and_history": []
