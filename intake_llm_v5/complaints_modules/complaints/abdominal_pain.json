  "escalation_rules": [
    {
      "name": "possible_aortic_catastrophe_abdominal_pain",
      "escalation_level": "immediate_alert",
      "condition": {
        "op": "all",
        "conditions": [
          {
            "field_ref": "$state.abdominal_pain",
            "op": "field_equals",
            "value": "yes"
          },
          {
            "op": "any",
            "conditions": [
              {
                "field_ref": "$state.tearing_pain",
                "op": "field_equals",
                "value": "yes"
              },
              {
                "field_ref": "$state.abdominal_pulsation",
                "op": "field_equals",
                "value": "yes"
              }
            ]
          }
        ]
      }
    },
