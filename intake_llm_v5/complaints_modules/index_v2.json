  "global_orchestration": {
    "session_flow_order": [
      "load_shared",
      "load_index",
      "open_complaint",
      "run_complaint_core_flow",
      "run_high_priority_followup",
      "run_targeted_followup",
      "run_modules",
      "run_ros",
      "run_final_closeout"
    ],
    "module_run_point_default": "after_targeted_followup_before_ros",
    "ros_run_point_default": "after_modules",
    "deduplication_principle": "Canonical concept deduplication must apply across complaint flow, modules, ROS, and overlapping complaints.",
