{
  "version": "1.0.0",
  "complaint_id": "trauma",
  "display_name": "Trauma",
  "ui_name": "Trauma",
  "ui_label": "Trauma",
  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "trauma_musculoskeletal",
  "related_systems": {
    "high_yield": [
      "neurological",
      "vascular",
      "thoracoabdominal"
    ],
    "selective_cross_system": [
      "genitourinary",
      "pregnancy"
    ],
    "contextual": [
      "mechanism_safety",
      "abuse_concern"
    ]
  },
  "pivot_triggers": {
    "weakness": "spinal_injury_pattern",
    "chest_pain": "thoracoabdominal_injury_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": [
      "presenting_complaint_narrative",
      "time_of_injury",
      "mechanism",
      "location_of_injury",
      "pain_severity",
      "functional_loss"
    ],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 30,
      "target_question_budget": 35,
      "max_questions": 40,
      "early_danger_reserve": 4,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Trauma requires thorough neurological, vascular, and thoracoabdominal screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": [
        "time_of_injury",
        "mechanism",
        "location_of_injury",
        "pain_severity"
      ],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "trauma_musculoskeletal"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": [
      "opening",
      "core_characterize",
      "early_danger_screen",
      "extended_characterize",
      "critical_followup",
      "high_priority_followup",
      "context_and_history"
    ],
    "default_profile": {
      "opening": [
        "presenting_complaint_narrative"
      ],
      "core_characterize": [
        "time_of_injury",
        "mechanism",
        "location_of_injury",
        "pain_severity",
        "functional_loss"
      ],
      "early_danger_screen": [
        "loss_of_consciousness",
        "neck_or_back_pain",
        "trauma_present",
        "trauma_present_details",
        "post_injury_headache",
        "post_injury_vomiting",
        "post_injury_confusion"
      ],
      "extended_characterize": [
        "bleeding",
        "swelling_or_deformity"
      ],
      "critical_followup": [
        "abdominal_pain",
        "major_bleeding",
        "distal_color_coldness_or_pulselessness"
      ],
      "high_priority_followup": [
        "associated_symptoms",
        "limb_swelling",
        "inability_to_bear_weight",
        "urinary_or_bowel_change",
        "anticoagulant_use",
        "weapon_or_high_energy_mechanism",
        "prior_injury_same_site",
        "assault_or_safeguarding_concern",
        "tetanus_immunization_status"
      ],
      "context_and_history": []
    },
    "chronic_low_severity_profile": {
      "opening": [
        "presenting_complaint_narrative"
      ],
      "core_characterize": [
        "time_of_injury",
        "mechanism",
        "location_of_injury",
        "pain_severity",
        "functional_loss"
      ],
      "early_danger_screen": [
        "loss_of_consciousness",
        "neck_or_back_pain",
        "trauma_present",
        "trauma_present_details",
        "post_injury_headache",
        "post_injury_vomiting",
        "post_injury_confusion",
        "recent_change_in_pattern"
      ],
      "extended_characterize": [
        "bleeding",
        "swelling_or_deformity"
      ],
      "critical_followup": [
        "abdominal_pain",
        "major_bleeding",
        "distal_color_coldness_or_pulselessness"
      ],
      "high_priority_followup": [
        "associated_symptoms",
        "limb_swelling",
        "inability_to_bear_weight",
        "urinary_or_bowel_change",
        "anticoagulant_use",
        "weapon_or_high_energy_mechanism",
        "prior_injury_same_site",
        "assault_or_safeguarding_concern",
        "tetanus_immunization_status"
      ],
      "context_and_history": []
    },
    "profile_switch_rules": [
      {
        "rule_id": "chronic_low_severity",
        "trigger": {
          "op": "all",
          "conditions": [
            {
              "op": "duration_gte",
              "field_ref": "duration",
              "value": 4,
              "unit": "weeks"
            },
            {
              "op": "field_below",
              "field_ref": "pain_severity",
              "value": 6
            }
          ]
        },
        "action": "use chronic_low_severity_profile"
      },
      {
        "rule_id": "stay_on_default",
        "trigger": "No alternate complaint-specific profile is active",
        "action": "use default_profile"
      }
    ]
  },
