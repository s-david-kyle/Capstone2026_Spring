        "anxiety_context"
      ],
      "critical_followup": [
        "exertional_trigger",
        "rapid_or_irregular_rhythm",
        "family_history_sudden_death",
        "structural_heart_disease"
      ],
      "high_priority_followup": [
        "associated_symptoms",
        "positional_or_vagal_trigger",
        "caffeine_alcohol_trigger",
        "thyroid_symptoms",
        "new_medication",
