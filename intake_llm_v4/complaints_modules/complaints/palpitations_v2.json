  "can_be_primary": true,
  "can_be_secondary": true,
  "primary_system": "cardiovascular",
  "related_systems": {
    "high_yield": [
      "respiratory",
      "neurological",
      "metabolic_endocrine"
    ],
    "selective_cross_system": [
      "anxiety",
      "structural_cardiac"
    ],
    "contextual": [
      "substance_medication",
      "thyroid"
    ]
  },
  "pivot_triggers": {
    "chest_pain": "chest_pain_pattern",
    "syncope": "cardiac_syncope_pattern"
  },
  "start_sequence_contract": {
    "approved_start_sequence": [
      "presenting_complaint_narrative",
      "onset",
      "duration",
      "frequency",
      "character"
    ],
    "sequence_mode": "complaint_owned",
    "default_rule": "Run the complaint-defined start sequence, then follow question_schedule.default_profile in listed order unless an explicit alternate profile is selected."
  },
  "question_budget": {
    "primary_mode": {
      "min_questions": 25,
      "target_question_budget": 28,
      "max_questions": 32,
      "early_danger_reserve": 3,
      "ros_reserve": 3,
      "context_history_reserve": 3,
      "rationale": "Palpitations require thorough cardiac, arrhythmia, and metabolic screening. Increased budget to ensure danger follow-ups and modules are completed."
    },
    "secondary_mode": {
      "secondary_question_budget": 4,
      "secondary_question_budget_override_if_red_flag": 7,
      "priority_question_ids_if_secondary": [
        "onset",
        "duration",
        "frequency",
        "character"
      ],
      "selection_rule": "If this complaint is secondary, ask only the listed priority questions unless a red-flag branch activates or unresolved shared danger concepts remain."
    },
    "ros_mode": {
      "target_ros_questions": 3,
      "max_ros_questions": 4,
      "pathological_system_first": true,
      "pathological_system": "cardiovascular"
    },
    "context_mode": {
      "target_context_questions": 3,
      "max_context_questions": 4
    },
    "reallocation_rules": [
      "If urgent red flags are active, borrow from extended_characterize and high_priority_followup before borrowing from context history.",
      "If the complaint is secondary and no danger trigger is active, remain within secondary_question_budget."
    ]
  },
  "question_schedule": {
    "enforced_phase_order": [
      "opening",
      "core_characterize",
      "early_danger_screen",
      "extended_characterize",
      "critical_followup",
      "high_priority_followup",
